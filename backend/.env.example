BACKEND_PORT=3001

# Spotify API — crea una app en https://developer.spotify.com/dashboard
# Solo necesitas Client Credentials (no requiere login del usuario)
SPOTIFY_CLIENT_ID=tu_client_id_aqui
SPOTIFY_CLIENT_SECRET=tu_client_secret_aqui

# Dominio del frontend (para CORS)
FRONTEND_ORIGIN=https://rayvermusic.com

# Ruta de la base de datos SQLite (opcional, por defecto ./data/rayver.db)
# DB_PATH=/app/data/rayver.db
