BACKEND_PORT=3001

# ── Spotify API ────────────────────────────────────────────────────────────────
# Crea una app en https://developer.spotify.com/dashboard (gratis)
# Solo necesitas Client Credentials — no requiere login del usuario
SPOTIFY_CLIENT_ID=tu_client_id_aqui
SPOTIFY_CLIENT_SECRET=tu_client_secret_aqui

# ── YouTube Data API v3 ────────────────────────────────────────────────────────
# 1. Ve a https://console.cloud.google.com
# 2. Crea un proyecto → Habilita "YouTube Data API v3"
# 3. Credenciales → Crear clave de API
# Cuota: 10.000 unidades/día gratis (cada búsqueda usa ~100 unidades)
YOUTUBE_API_KEY=tu_api_key_aqui

# IDs de tus canales de YouTube separados por coma
# Para encontrar el ID: en YouTube Studio → Configuración → Información del canal → ID del canal
# O desde la URL: youtube.com/channel/UC... → el UC... es el ID
YOUTUBE_CHANNEL_IDS=UCxxxxxxxxxxxxxxxxxxxxxxxx,UCyyyyyyyyyyyyyyyyyyyyyyyy

# ── General ────────────────────────────────────────────────────────────────────
# Dominio del frontend (para CORS)
FRONTEND_ORIGIN=https://rayvermusic.com

# Ruta de la base de datos SQLite (opcional, por defecto ./data/rayver.db)
# DB_PATH=/app/data/rayver.db
